{#-
  .kiro/settings/mcp.json — MANAGED (when 'kiro' in agentic_targets AND mcp_config=true).

  Kiro MCP server configuration. Re-rendered byte-identically at reproduce.
  NOTE: After scaffold, open the Kiro IDE and toggle "Enable MCP servers" ON
  (see AGENTIC.md for the one-time IDE setup step).
-#}
{
  "mcpServers": {
{% for server in mcp_servers %}
    "{{ server.name }}": {
      "command": "{{ server.command }}"{% if server.args is defined and server.args %},
      "args": {{ server.args | tojson }}{% endif %}{% if server.env is defined and server.env %},
      "env": {
{% for key, val in server.env.items() %}
        "{{ key }}": "{{ val }}"{% if not loop.last %},{% endif %}
{% endfor %}
      }{% endif %}
    }{% if not loop.last %},{% endif %}
{% endfor %}
  }
}
