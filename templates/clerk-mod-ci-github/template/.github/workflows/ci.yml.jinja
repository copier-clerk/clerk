{#- clerk-mod-ci-github: GitHub Actions CI workflow template
 #
 # Pure managed render — ZERO _tasks. Byte-identical on reproduce.
 # ALL sizing facts (ci_languages, ci_lang_facts) are AGENT-FROZEN via --data.
 # Contract: specs/011-deopinionated-module-family/contracts/ci-github-gitlab.md
 #
 # Pinned action majors (current as of 2026-07):
 #   actions/checkout@v4
 #   actions/setup-python@v5
 #   actions/setup-node@v4
 #   actions/setup-go@v5
 #   dtolnay/rust-toolchain@stable  (stable is the pin — no major tag exists)
 #   actions/cache@v4
 #   dorny/paths-filter@v3
 #   actions/upload-artifact@v4   ← upload and download MUST share major (v4)
 #   actions/download-artifact@v4
 #
 # R4 fail-loud guard: ci_languages==[] AND monorepo_tool==none → warning comment
 # + no-op job so the misconfiguration is visible, not a silent empty file.
 -#}
{%- set _is_empty = (ci_languages | length == 0) and (monorepo_tool == "none" or not monorepo_tool) -%}
{%- set _is_monorepo = ci_model == "monorepo-affected" -%}
{%- set _is_merge_queue = ci_model == "merge-queue" -%}
{%- set _is_optimized = ci_model == "optimized" -%}
{%- set _is_minimal = ci_model == "minimal" -%}
{%- set _has_gate = ci_required_gate and not _is_minimal -%}
{%- set _default_branch = default_branch if (default_branch and default_branch != "{{ default_branch }}") else "main" -%}
{%- set _oidc_enabled = ci_oidc_provider and ci_oidc_provider != "none" -%}
{%- set _langs = ci_languages | list -%}
# Generated by clerk-mod-ci-github — do not edit by hand.
# Model: {{ ci_model }}
{% if _is_empty %}
# WARNING: ci_languages is empty and monorepo_tool is not set.
# No language jobs will be generated. Inject ci_languages (and optionally
# ci_lang_facts) via --data to produce a meaningful CI workflow.
# This no-op guard exists to make the misconfiguration visible (R4).
{% endif %}
name: CI

on:
  push:
    branches: ["{{ _default_branch }}"]
  pull_request:
    branches: ["{{ _default_branch }}"]
{% if _is_merge_queue %}
  merge_group:
    types: [checks_requested]
{% endif %}
{% if ci_concurrency_cancel %}
concurrency:
  group: ${{ '{{' }} github.workflow }}-${{ '{{' }} github.ref }}
  cancel-in-progress: true

{% endif %}
{% if _oidc_enabled %}
permissions:
  contents: read
  id-token: write

{% endif %}
jobs:
{% if _is_empty %}
  ci-misconfigured:
    name: CI misconfigured — inject ci_languages
    runs-on: ubuntu-latest
    steps:
      - name: Fail with guidance
        run: |
          echo "::error::clerk-mod-ci-github: ci_languages is empty and monorepo_tool is not set."
          echo "Inject ci_languages and ci_lang_facts via --data when running copier."
          exit 1
{% elif _is_minimal %}

  ci:
    name: CI
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
  {%- for lang in _langs %}
    {%- set facts = ci_lang_facts.get(lang, {}) %}
    {%- set manager = facts.get("manager", "") %}
    {%- set version = facts.get("version", "") %}
    {%- set test_runner = facts.get("test_runner", "none") %}
    {%- if lang == "python" %}

      - name: Set up Python {{ version }}
        uses: actions/setup-python@v5
        with:
          python-version: "{{ version }}"
      {%- if manager == "uv" %}

      - name: Install uv
        run: pip install uv --quiet

      - name: Install dependencies
        run: uv sync --frozen
      {%- elif manager == "pdm" %}

      - name: Install pdm
        run: pip install pdm --quiet

      - name: Install dependencies
        run: pdm install
      {%- else %}

      - name: Install dependencies
        run: pip install -e ".[dev]"
      {%- endif %}
      {%- if test_runner != "none" and test_runner %}

      - name: Lint + test
        run: |
          {%- if manager == "uv" %}
          uv run ruff check .
          uv run ruff format --check .
          uv run {{ test_runner }}
          {%- else %}
          ruff check .
          ruff format --check .
          {{ test_runner }}
          {%- endif %}
      {%- endif %}
    {%- elif lang == "typescript" %}

      - name: Set up Node {{ version }}
        uses: actions/setup-node@v4
        with:
          node-version: "{{ version }}"
      {%- if manager == "bun" %}

      - name: Set up Bun
        uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest

      - name: Install dependencies
        run: bun install --frozen-lockfile
      {%- elif manager == "pnpm" %}

      - name: Set up pnpm
        uses: pnpm/action-setup@v4
        with:
          run_install: false

      - name: Install dependencies
        run: pnpm install --frozen-lockfile
      {%- else %}

      - name: Install dependencies
        run: npm ci
      {%- endif %}
      {%- if test_runner != "none" and test_runner %}

      - name: Lint + test
        run: |
          {%- if manager == "bun" %}
          bunx biome check --no-errors-on-unmatched
          bun run {{ test_runner }}
          {%- elif manager == "pnpm" %}
          pnpm dlx biome check --no-errors-on-unmatched
          pnpm run {{ test_runner }}
          {%- else %}
          npx biome check --no-errors-on-unmatched
          npm run {{ test_runner }}
          {%- endif %}
      {%- endif %}
    {%- elif lang == "go" %}

      - name: Set up Go {{ version }}
        uses: actions/setup-go@v5
        with:
          go-version: "{{ version }}"

      - name: Download modules
        run: go mod download
      {%- if test_runner != "none" and test_runner %}

      - name: Lint + test
        uses: golangci/golangci-lint-action@v6
        with:
          version: latest

      - name: Test
        run: go test ./...
      {%- endif %}
    {%- elif lang == "rust" %}

      - name: Set up Rust stable
        uses: dtolnay/rust-toolchain@stable
        with:
          components: rustfmt, clippy
      {%- if test_runner != "none" and test_runner %}

      - name: Lint + test
        run: |
          cargo fmt --check
          cargo clippy -- -D warnings
          cargo {{ test_runner }}
      {%- endif %}
    {%- endif %}
  {%- endfor %}

{%- elif _is_monorepo %}

  changes:
    name: Detect changed packages
    runs-on: ubuntu-latest
    outputs:
      any_changed: ${{ '{{' }} steps.filter.outputs.changes }}
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - name: Detect package changes
        id: filter
        uses: dorny/paths-filter@v3
        with:
          filters: |
            packages:
              - '**'
  {%- for lang in _langs %}
    {%- set facts = ci_lang_facts.get(lang, {}) %}
    {%- set manager = facts.get("manager", "") %}
    {%- set version = facts.get("version", "") %}
    {%- set test_runner = facts.get("test_runner", "none") %}

  {{ lang }}-ci:
    name: "{{ lang | title }} (affected)"
    needs: [changes]
    if: ${{ '{{' }} needs.changes.outputs.any_changed != '[]' }}
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
    {%- if lang == "python" %}
      - uses: actions/setup-python@v5
        with:
          python-version: "{{ version }}"
      {%- if ci_cache %}
      - uses: actions/cache@v4
        with:
          path: ~/.cache/uv
          key: ${{ '{{' }} runner.os }}-uv-${{ '{{' }} hashFiles('**/uv.lock') }}
          restore-keys: ${{ '{{' }} runner.os }}-uv-
      {%- endif %}
      {%- if manager == "uv" %}
      - run: pip install uv --quiet
      - run: uv sync --frozen
      {%- endif %}
      {%- if test_runner != "none" and test_runner %}
      - run: uv run ruff check .
      - run: uv run ruff format --check .
      - run: uv run {{ test_runner }}
      {%- endif %}
    {%- elif lang == "typescript" %}
      - uses: actions/setup-node@v4
        with:
          node-version: "{{ version }}"
      {%- if ci_cache %}
      - uses: actions/cache@v4
        with:
          path: ~/.bun/install/cache
          key: ${{ '{{' }} runner.os }}-bun-${{ '{{' }} hashFiles('**/bun.lock') }}
          restore-keys: ${{ '{{' }} runner.os }}-bun-
      {%- endif %}
      {%- if manager == "bun" %}
      - uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest
      - run: bun install --frozen-lockfile
      {%- endif %}
      {%- if test_runner != "none" and test_runner %}
      - run: bunx biome check --no-errors-on-unmatched
      - run: bun run {{ test_runner }}
      {%- endif %}
    {%- elif lang == "go" %}
      - uses: actions/setup-go@v5
        with:
          go-version: "{{ version }}"
      {%- if ci_cache %}
      - uses: actions/cache@v4
        with:
          path: ~/go/pkg/mod
          key: ${{ '{{' }} runner.os }}-go-${{ '{{' }} hashFiles('**/go.sum') }}
          restore-keys: ${{ '{{' }} runner.os }}-go-
      {%- endif %}
      - run: go mod download
      {%- if test_runner != "none" and test_runner %}
      - uses: golangci/golangci-lint-action@v6
        with:
          version: latest
      - run: go test ./...
      {%- endif %}
    {%- elif lang == "rust" %}
      - uses: dtolnay/rust-toolchain@stable
        with:
          components: rustfmt, clippy
      {%- if ci_cache %}
      - uses: actions/cache@v4
        with:
          path: |
            ~/.cargo/registry
            ~/.cargo/git
            target
          key: ${{ '{{' }} runner.os }}-cargo-${{ '{{' }} hashFiles('**/Cargo.lock') }}
          restore-keys: ${{ '{{' }} runner.os }}-cargo-
      {%- endif %}
      {%- if test_runner != "none" and test_runner %}
      - run: cargo fmt --check
      - run: cargo clippy -- -D warnings
      - run: cargo {{ test_runner }}
      {%- endif %}
    {%- endif %}
  {%- endfor %}
  {%- if _has_gate %}

  gate:
    name: Required gate
    needs: [{{ _langs | map("regex_replace", "$", "-ci") | join(", ") }}]
    runs-on: ubuntu-latest
    if: always()
    steps:
      - name: Check all jobs passed
        run: |
          results='${{ '{{' }} toJSON(needs) }}'
          if echo "$results" | grep -q '"result": "failure"'; then
            echo "One or more CI jobs failed."
            exit 1
          fi
          echo "All required checks passed."
  {%- endif %}

{%- elif _is_merge_queue %}

  {%- if not merge_queue_org_confirmed %}
  # WARNING: merge_queue_org_confirmed is false. Merge queue requires a GitHub org
  # or GHEC subscription. Set merge_queue_org_confirmed: true only with a confirmed
  # org/GHEC signal. Rendering without merge_group trigger guards.
  {%- endif %}
  {%- for lang in _langs %}
    {%- set facts = ci_lang_facts.get(lang, {}) %}
    {%- set manager = facts.get("manager", "") %}
    {%- set version = facts.get("version", "") %}
    {%- set test_runner = facts.get("test_runner", "none") %}

  {{ lang }}-ci:
    name: "{{ lang | title }} CI"
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
    {%- if lang == "python" %}
      - uses: actions/setup-python@v5
        with:
          python-version: "{{ version }}"
      {%- if ci_cache %}
      - uses: actions/cache@v4
        with:
          path: ~/.cache/uv
          key: ${{ '{{' }} runner.os }}-uv-${{ '{{' }} hashFiles('**/uv.lock') }}
          restore-keys: ${{ '{{' }} runner.os }}-uv-
      {%- endif %}
      {%- if manager == "uv" %}
      - run: pip install uv --quiet
      - run: uv sync --frozen
      {%- endif %}
      {%- if test_runner != "none" and test_runner %}
      - run: uv run ruff check .
      - run: uv run ruff format --check .
      - run: uv run {{ test_runner }}
      {%- endif %}
    {%- elif lang == "typescript" %}
      - uses: actions/setup-node@v4
        with:
          node-version: "{{ version }}"
      {%- if ci_cache %}
      - uses: actions/cache@v4
        with:
          path: ~/.bun/install/cache
          key: ${{ '{{' }} runner.os }}-bun-${{ '{{' }} hashFiles('**/bun.lock') }}
          restore-keys: ${{ '{{' }} runner.os }}-bun-
      {%- endif %}
      {%- if manager == "bun" %}
      - uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest
      - run: bun install --frozen-lockfile
      {%- endif %}
      {%- if test_runner != "none" and test_runner %}
      - run: bunx biome check --no-errors-on-unmatched
      - run: bun run {{ test_runner }}
      {%- endif %}
    {%- elif lang == "go" %}
      - uses: actions/setup-go@v5
        with:
          go-version: "{{ version }}"
      {%- if ci_cache %}
      - uses: actions/cache@v4
        with:
          path: ~/go/pkg/mod
          key: ${{ '{{' }} runner.os }}-go-${{ '{{' }} hashFiles('**/go.sum') }}
          restore-keys: ${{ '{{' }} runner.os }}-go-
      {%- endif %}
      - run: go mod download
      {%- if test_runner != "none" and test_runner %}
      - uses: golangci/golangci-lint-action@v6
        with:
          version: latest
      - run: go test ./...
      {%- endif %}
    {%- elif lang == "rust" %}
      - uses: dtolnay/rust-toolchain@stable
        with:
          components: rustfmt, clippy
      {%- if ci_cache %}
      - uses: actions/cache@v4
        with:
          path: |
            ~/.cargo/registry
            ~/.cargo/git
            target
          key: ${{ '{{' }} runner.os }}-cargo-${{ '{{' }} hashFiles('**/Cargo.lock') }}
          restore-keys: ${{ '{{' }} runner.os }}-cargo-
      {%- endif %}
      {%- if test_runner != "none" and test_runner %}
      - run: cargo fmt --check
      - run: cargo clippy -- -D warnings
      - run: cargo {{ test_runner }}
      {%- endif %}
    {%- endif %}
  {%- endfor %}

  gate:
    name: Required gate
    needs: [{{ _langs | map("regex_replace", "$", "-ci") | join(", ") }}]
    runs-on: ubuntu-latest
    if: always()
    steps:
      - name: Check all jobs passed
        run: |
          results='${{ '{{' }} toJSON(needs) }}'
          if echo "$results" | grep -q '"result": "failure"'; then
            echo "One or more CI jobs failed."
            exit 1
          fi
          echo "All required checks passed."

{%- else %}

  {%- if _is_optimized %}

  changes:
    name: Detect changed files
    runs-on: ubuntu-latest
    outputs:
    {%- for lang in _langs %}
      {{ lang }}: ${{ '{{' }} steps.filter.outputs.{{ lang }} }}
    {%- endfor %}
    steps:
      - uses: actions/checkout@v4
      - name: Detect changes
        id: filter
        uses: dorny/paths-filter@v3
        with:
          filters: |
          {%- for lang in _langs %}
            {{ lang }}:
            {%- if lang == "python" %}
              - '**/*.py'
              - 'pyproject.toml'
              - 'uv.lock'
            {%- elif lang == "typescript" %}
              - '**/*.ts'
              - '**/*.tsx'
              - 'package.json'
              - 'bun.lock'
              - 'pnpm-lock.yaml'
            {%- elif lang == "go" %}
              - '**/*.go'
              - 'go.mod'
              - 'go.sum'
            {%- elif lang == "rust" %}
              - '**/*.rs'
              - 'Cargo.toml'
              - 'Cargo.lock'
            {%- else %}
              - '**'
            {%- endif %}
          {%- endfor %}
  {%- endif %}
  {%- for lang in _langs %}
    {%- set facts = ci_lang_facts.get(lang, {}) %}
    {%- set manager = facts.get("manager", "") %}
    {%- set version = facts.get("version", "") %}
    {%- set test_runner = facts.get("test_runner", "none") %}

  {{ lang }}-ci:
    name: "{{ lang | title }} CI"
    {%- if _is_optimized %}
    needs: [changes]
    if: ${{ '{{' }} needs.changes.outputs.{{ lang }} == 'true' }}
    {%- endif %}
    runs-on: ubuntu-latest
    {%- if (ci_os_matrix | length) > 0 or (ci_matrix_versions | length) > 0 %}
    strategy:
      matrix:
        os: {{ (["ubuntu-latest"] + ci_os_matrix) | tojson }}
        {%- if (ci_matrix_versions | length) > 0 %}
        version: {{ ci_matrix_versions | tojson }}
        {%- endif %}
    {%- endif %}
    steps:
      - uses: actions/checkout@v4
    {%- if lang == "python" %}
      - uses: actions/setup-python@v5
        with:
          python-version: "{{ version }}"
      {%- if ci_cache %}
      - uses: actions/cache@v4
        with:
          path: ~/.cache/uv
          key: ${{ '{{' }} runner.os }}-uv-${{ '{{' }} hashFiles('**/uv.lock') }}
          restore-keys: ${{ '{{' }} runner.os }}-uv-
      {%- endif %}
      {%- if manager == "uv" %}
      - run: pip install uv --quiet
      - run: uv sync --frozen
      {%- elif manager == "pdm" %}
      - run: pip install pdm --quiet
      - run: pdm install
      {%- else %}
      - run: pip install -e ".[dev]"
      {%- endif %}
      {%- if test_runner != "none" and test_runner %}
      - run: |
          {%- if manager == "uv" %}
          uv run ruff check .
          uv run ruff format --check .
          uv run {{ test_runner }}
          {%- else %}
          ruff check .
          ruff format --check .
          {{ test_runner }}
          {%- endif %}
      {%- endif %}
    {%- elif lang == "typescript" %}
      - uses: actions/setup-node@v4
        with:
          node-version: "{{ version }}"
      {%- if manager == "bun" %}
      - uses: oven-sh/setup-bun@v2
        with:
          bun-version: latest
      {%- if ci_cache %}
      - uses: actions/cache@v4
        with:
          path: ~/.bun/install/cache
          key: ${{ '{{' }} runner.os }}-bun-${{ '{{' }} hashFiles('**/bun.lock') }}
          restore-keys: ${{ '{{' }} runner.os }}-bun-
      {%- endif %}
      - run: bun install --frozen-lockfile
      {%- elif manager == "pnpm" %}
      - uses: pnpm/action-setup@v4
        with:
          run_install: false
      {%- if ci_cache %}
      - uses: actions/cache@v4
        with:
          path: ~/.pnpm-store
          key: ${{ '{{' }} runner.os }}-pnpm-${{ '{{' }} hashFiles('**/pnpm-lock.yaml') }}
          restore-keys: ${{ '{{' }} runner.os }}-pnpm-
      {%- endif %}
      - run: pnpm install --frozen-lockfile
      {%- else %}
      - run: npm ci
      {%- endif %}
      {%- if test_runner != "none" and test_runner %}
      - run: |
          {%- if manager == "bun" %}
          bunx biome check --no-errors-on-unmatched
          bun run {{ test_runner }}
          {%- elif manager == "pnpm" %}
          pnpm dlx biome check --no-errors-on-unmatched
          pnpm run {{ test_runner }}
          {%- else %}
          npx biome check --no-errors-on-unmatched
          npm run {{ test_runner }}
          {%- endif %}
      {%- endif %}
    {%- elif lang == "go" %}
      - uses: actions/setup-go@v5
        with:
          go-version: "{{ version }}"
      {%- if ci_cache %}
      - uses: actions/cache@v4
        with:
          path: ~/go/pkg/mod
          key: ${{ '{{' }} runner.os }}-go-${{ '{{' }} hashFiles('**/go.sum') }}
          restore-keys: ${{ '{{' }} runner.os }}-go-
      {%- endif %}
      - run: go mod download
      {%- if test_runner != "none" and test_runner %}
      - uses: golangci/golangci-lint-action@v6
        with:
          version: latest
      - run: go test ./...
      {%- endif %}
    {%- elif lang == "rust" %}
      - uses: dtolnay/rust-toolchain@stable
        with:
          components: rustfmt, clippy
      {%- if ci_cache %}
      - uses: actions/cache@v4
        with:
          path: |
            ~/.cargo/registry
            ~/.cargo/git
            target
          key: ${{ '{{' }} runner.os }}-cargo-${{ '{{' }} hashFiles('**/Cargo.lock') }}
          restore-keys: ${{ '{{' }} runner.os }}-cargo-
      {%- endif %}
      {%- if test_runner != "none" and test_runner %}
      - run: cargo fmt --check
      - run: cargo clippy -- -D warnings
      - run: cargo {{ test_runner }}
      {%- endif %}
    {%- endif %}
  {%- endfor %}
  {%- if _has_gate %}

  gate:
    name: Required gate
    needs: [{{ _langs | map("regex_replace", "$", "-ci") | join(", ") }}]
    runs-on: ubuntu-latest
    if: always()
    steps:
      - name: Check all jobs passed
        run: |
          results='${{ '{{' }} toJSON(needs) }}'
          if echo "$results" | grep -q '"result": "failure"'; then
            echo "One or more CI jobs failed."
            exit 1
          fi
          echo "All required checks passed."
  {%- endif %}

{%- endif %}
