{#-
  pyproject.toml — SEED-ONCE (_skip_if_exists in copier.yml).

  Ports lang-python's Python manifest (uv + ruff). Seeded once, then the project
  owns and evolves it (adds/bumps deps). `requires-python` is pinned from the
  `python_version` answer; dependencies render from the agent-resolved
  pinned_deps / dev_deps answers (empty by default → no deps, faithful to
  lang-python: "empty → no deps written").

  Reconciled against lang-python-v1.3.0 (module.py). Two clerk-model adaptations:
    - ruff `target-version` is threaded from python_version (upstream hardcodes
      "py313"); the rest of the ruff block is byte-faithful.
    - lang-python runs `uv init --name <project> --package`, producing an
      installable src/<snake_name>/ layout with [build-system] + [project.scripts].
      That is a uv-driven task (it picks the build backend + entrypoint), not a
      static render; reproducing uv's exact choices in a seed would invent them.
      FLAGGED, not ported: Phase 0 seeds a flat manifest. Add the src-package
      layout via a uv-init task if/when installable packaging is required.
-#}
[project]
name = "{{ project_name | default('project', true) | lower | replace(' ', '-') | replace('_', '-') }}"
version = "0.1.0"
description = "{{ description }}"
requires-python = ">={{ python_version }}"
dependencies = [{% for dep in pinned_deps %}"{{ dep | replace('@', '==') }}"{{ ", " if not loop.last else "" }}{% endfor %}]

[dependency-groups]
dev = [{% for dep in dev_deps %}"{{ dep | replace('@', '==') }}"{{ ", " if not loop.last else "" }}{% endfor %}]

# ruff config — byte-faithful to lang-python-v1.3.0 (templates/ruff-config.toml),
# except target-version, which is threaded from python_version (upstream: "py313").
[tool.ruff]
target-version = "py{{ python_version | replace('.', '') }}"
line-length = 100

[tool.ruff.lint]
select = ["E", "F", "I", "N", "W", "UP", "B", "SIM", "TCH"]

[tool.ruff.format]
quote-style = "double"
