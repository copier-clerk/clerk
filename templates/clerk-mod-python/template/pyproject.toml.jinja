{#-
  pyproject.toml — SEED-ONCE (_skip_if_exists in copier.yml).

  Ports lang-python's Python manifest (uv + ruff + pytest). Seeded once, then
  the project owns and evolves it (adds/bumps deps). `requires-python` is pinned
  from the `python_version` answer.

  SOURCE CAVEAT: lang-python's manifest is not locally present (see copier.yml).
  The specific tool config below is INFERRED from the SKILL.md characterization
  ("uv, ruff, pytest"; pins the chosen Python). Every inferred block carries a
  TODO(009) flag so it can be reconciled against the real manifest later.
-#}
[project]
name = "{{ project_name | default('project', true) | lower | replace(' ', '-') | replace('_', '-') }}"
version = "0.1.0"
requires-python = ">={{ python_version }}"
dependencies = []

# TODO(009): confirm [project] fields (description/authors/readme/license) against
# the lang-python manifest when available — kept minimal here to avoid inventing
# fields beyond the SKILL.md characterization (FR-011).

[dependency-groups]
dev = [
  "ruff",
  "pytest",
]

[tool.ruff]
# TODO(009): confirm ruff target-version / line-length / lint selection against
# the lang-python manifest. target-version tracks the pinned python_version.
target-version = "py{{ python_version | replace('.', '') }}"

[tool.pytest.ini_options]
# TODO(009): confirm pytest config (testpaths/addopts) against the lang-python
# manifest.
testpaths = ["tests"]
