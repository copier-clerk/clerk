{#-
  .pre-commit.d/bailiff-mod-terraform.yaml — own hook block only, rendered unconditionally.
  bailiff-mod-precommit's bundler merges all .pre-commit.d/*.yaml into
  .pre-commit-config.yaml as a _post_task; this fragment is inert when precommit is absent
  (FR-011/012, _fragment-merge.md).
-#}
repos:
  - repo: https://github.com/antonbabenko/pre-commit-terraform
    {% if pre_commit_terraform_rev -%}
    rev: "{{ pre_commit_terraform_rev }}"
    {% else -%}
    rev: ""  # pin via pre_commit_terraform_rev answer or update manually
    {% endif -%}
    hooks:
      - id: terraform_fmt
      - id: terraform_validate
      - id: tflint
      - id: terraform_trivy
