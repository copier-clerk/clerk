{#-
  .tflint.hcl — MANAGED (byte-identical on init and reproduce).

  Enables the terraform ruleset. Cloud-provider rulesets (aws, azurerm, google)
  are shown as commented examples — add and uncomment for your provider.
  tfsec is DEAD; trivy is the replacement for security scanning (via
  antonbabenko/pre-commit-terraform hooks contributed to hook_blocks).
-#}
plugin "terraform" {
  enabled = true
  preset  = "recommended"
}

# Cloud-provider rulesets — uncomment and pin to use:
