{#
  .gitlab-ci.yml - MANAGED (byte-identical at reproduce).

  Renders a GitLab CI pipeline from the frozen answers injected by the phase-1
  agent. ZERO _tasks: this file IS the output. Grill fixes applied throughout:
  - workflow:rules canonical duplicate-pipeline guard (ALL models)
  - optional:true needs on change-gated jobs (pipeline-creation safe)
  - coupled interruptible + workflow:auto_cancel:on_new_commit as one unit
  - rules:changes compare_to on branch arm only, omitted on MR arm
  - fallback_keys on all caches
  - pinned images from ci_lang_facts (no :latest/:lts)
  - bun.lock (not bun.lockb) cache key
  - gitlab_tier=free merge-queue fallback + header warning
  - empty ci_languages + monorepo_tool=none loud warning no-op job (R4)

  Contract: spec 011 T017 / contracts/ci-github-gitlab.md
#}
{%- set _no_languages = (ci_languages | default([]) | length == 0) %}
{%- set _no_monorepo  = (monorepo_tool | default('none') == 'none') %}
{%- set _guard_mode   = _no_languages and _no_monorepo and ci_model not in ['monorepo-affected'] %}
{%- set _lang_facts   = ci_lang_facts | default({}) %}
{%- set _languages    = ci_languages  | default([]) %}
# Generated by clerk-mod-ci-gitlab
# Model: {{ ci_model }}
{% if ci_model == 'merge-queue' and gitlab_tier == 'free' %}
# WARNING: merge trains require GitLab Premium/Ultimate. This pipeline uses the
# merge-when-pipeline-succeeds fallback (gitlab_tier=free). Upgrade gitlab_tier
# to premium_ultimate when merge trains are available on your instance.
{% endif %}
# Canonical workflow:rules duplicate-pipeline guard (prevents push+MR double run).
workflow:
  rules:
    - if: '$CI_PIPELINE_SOURCE == "push" && $CI_OPEN_MERGE_REQUESTS'
      when: never
    - when: always
{% if ci_model == 'optimized' and ci_concurrency_cancel %}
  auto_cancel:
    on_new_commit: interruptible
{% endif %}

{% if ci_model == 'minimal' or _guard_mode %}
stages:
  - ci
{% elif ci_model in ['standard', 'optimized', 'merge-queue'] %}
stages:
  - test
{% elif ci_model == 'monorepo-affected' %}
stages:
  - trigger
{% endif %}

{% if _languages and _lang_facts %}
{%- set _first_lang  = _languages[0] %}
{%- set _first_facts = _lang_facts[_first_lang] if (_first_lang in _lang_facts) else {} %}
{%- set _first_image = _first_facts['image'] if ('image' in _first_facts) else '' %}
{% if _first_image %}
default:
  image: {{ _first_image }}
{% endif %}
{% endif %}

{# ======================================================================
   GUARD MODE: loud warning no-op job when ci_languages=[] + monorepo=none.
   ====================================================================== #}
{% if _guard_mode %}
# WARNING: clerk-mod-ci-gitlab has no ci_languages configured.
# Inject ci_languages and ci_lang_facts via --data to generate real jobs.
# This no-op job keeps the pipeline green so CI is not blocked.
ci-misconfiguration-warning:
  stage: ci
  script:
    - echo "WARN: clerk-mod-ci-gitlab has no ci_languages configured."
    - echo "Inject ci_languages and ci_lang_facts via --data to generate jobs."
  allow_failure: false
{% else %}

{# ======================================================================
   MINIMAL: one job, multi-command script (NOT two needs-chained jobs).
   ====================================================================== #}
{% if ci_model == 'minimal' %}
ci:
  stage: ci
{% if ci_oidc_provider == 'gitlab' %}
  id_tokens:
    SIGSTORE_ID_TOKEN:
      aud: sigstore
{% endif %}
  script:
{% for lang in _languages %}
{%- set _facts = _lang_facts[lang] if (lang in _lang_facts and _lang_facts is mapping) else {} %}
{%- set _mgr   = _facts['manager'] if 'manager' in _facts else '' %}
{%- set _test  = _facts['test_runner'] if 'test_runner' in _facts else '' %}
{% if lang == 'python' %}
    - {{ _mgr if _mgr else 'uv' }} run ruff check .
    - {{ _mgr if _mgr else 'uv' }} run ruff format --check .
{% if _test %}
    - {{ _mgr if _mgr else 'uv' }} run {{ _test }}
{% endif %}
{% elif lang == 'typescript' %}
{% if _mgr == 'pnpm' %}
    - pnpm install --frozen-lockfile
    - pnpm run biome check .
    - pnpm run tsc --noEmit
{% if _test %}
    - pnpm run {{ _test }}
{% endif %}
{% else %}
    - bun install --frozen-lockfile
    - bun run biome check .
    - bun run tsc --noEmit
{% if _test %}
    - bun run {{ _test }}
{% endif %}
{% endif %}
{% elif lang == 'go' %}
    - golangci-lint run ./...
    - go test ./...
{% elif lang == 'rust' %}
    - cargo fmt --check
    - cargo clippy -- -D warnings
    - cargo nextest run
{% else %}
    - echo "ci: {{ lang }}"
{% endif %}
{% endfor %}
{% if not _languages %}
    - echo "ci"
{% endif %}

{# ======================================================================
   STANDARD: parallel per-language jobs. Stage order IS the gate —
   no explicit gate job, no deploy job.
   ====================================================================== #}
{% elif ci_model == 'standard' %}
{% set _std_langs = _languages if _languages else ['ci'] %}
{% for lang in _std_langs %}
{%- set _facts = _lang_facts[lang] if (_languages and lang in _lang_facts and _lang_facts is mapping) else {} %}
{%- set _mgr   = _facts['manager'] if 'manager' in _facts else '' %}
{%- set _test  = _facts['test_runner'] if 'test_runner' in _facts else '' %}
{%- set _img   = _facts['image'] if 'image' in _facts else '' %}

{{ lang }}:
  stage: test
{% if _img %}
  image: {{ _img }}
{% endif %}
{% if ci_oidc_provider == 'gitlab' %}
  id_tokens:
    SIGSTORE_ID_TOKEN:
      aud: sigstore
{% endif %}
  script:
{% if lang == 'python' %}
    - {{ _mgr if _mgr else 'uv' }} run ruff check .
    - {{ _mgr if _mgr else 'uv' }} run ruff format --check .
{% if _test %}
    - {{ _mgr if _mgr else 'uv' }} run {{ _test }}
{% endif %}
{% elif lang == 'typescript' %}
{% if _mgr == 'pnpm' %}
    - pnpm install --frozen-lockfile
    - pnpm run biome check .
    - pnpm run tsc --noEmit
{% if _test %}
    - pnpm run {{ _test }}
{% endif %}
{% else %}
    - bun install --frozen-lockfile
    - bun run biome check .
    - bun run tsc --noEmit
{% if _test %}
    - bun run {{ _test }}
{% endif %}
{% endif %}
{% elif lang == 'go' %}
    - golangci-lint run ./...
    - go test ./...
{% elif lang == 'rust' %}
    - cargo fmt --check
    - cargo clippy -- -D warnings
    - cargo nextest run
{% else %}
    - echo "ci: {{ lang }}"
{% endif %}
{% endfor %}

{# ======================================================================
   OPTIMIZED: standard + rules:changes + cache + interruptible.
   Skipped pipeline = success on GitLab → no status-shim needed.
   Grill fixes: compare_to on branch arm only; coupled interruptible +
   workflow:auto_cancel.
   ====================================================================== #}
{% elif ci_model == 'optimized' %}
{% set _opt_langs = _languages if _languages else ['ci'] %}
{% for lang in _opt_langs %}
{%- set _facts = _lang_facts[lang] if (_languages and lang in _lang_facts and _lang_facts is mapping) else {} %}
{%- set _mgr   = _facts['manager'] if 'manager' in _facts else '' %}
{%- set _test  = _facts['test_runner'] if 'test_runner' in _facts else '' %}
{%- set _img   = _facts['image'] if 'image' in _facts else '' %}

{{ lang }}:
  stage: test
{% if _img %}
  image: {{ _img }}
{% endif %}
{% if ci_concurrency_cancel %}
  interruptible: true
{% endif %}
{% if ci_oidc_provider == 'gitlab' %}
  id_tokens:
    SIGSTORE_ID_TOKEN:
      aud: sigstore
{% endif %}
  rules:
    # Branch push: run only when relevant files changed.
    - if: '$CI_COMMIT_BRANCH'
      changes:
        paths:
{% if lang == 'python' %}
          - "**/*.py"
          - "pyproject.toml"
          - "uv.lock"
{% elif lang == 'typescript' %}
          - "**/*.ts"
          - "**/*.tsx"
          - "package.json"
{% if _mgr == 'pnpm' %}
          - "pnpm-lock.yaml"
{% else %}
          - "bun.lock"
{% endif %}
{% elif lang == 'go' %}
          - "**/*.go"
          - "go.mod"
          - "go.sum"
{% elif lang == 'rust' %}
          - "**/*.rs"
          - "Cargo.toml"
          - "Cargo.lock"
{% else %}
          - "**/*"
{% endif %}
        compare_to: "refs/heads/{{ default_branch | default('main') }}"
    # MR pipeline: always run (compare_to omitted on MR arm — grill fix).
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
{% if ci_cache %}
  cache:
    key:
{% if lang == 'python' %}
      files:
        - uv.lock
      prefix: "{{ lang }}-$CI_COMMIT_REF_SLUG"
{% elif lang == 'typescript' %}
{% if _mgr == 'pnpm' %}
      files:
        - pnpm-lock.yaml
      prefix: "{{ lang }}-$CI_COMMIT_REF_SLUG"
{% else %}
      files:
        - bun.lock
      prefix: "{{ lang }}-$CI_COMMIT_REF_SLUG"
{% endif %}
{% elif lang == 'go' %}
      files:
        - go.sum
      prefix: "{{ lang }}-$CI_COMMIT_REF_SLUG"
{% elif lang == 'rust' %}
      files:
        - Cargo.lock
      prefix: "{{ lang }}-$CI_COMMIT_REF_SLUG"
{% else %}
      prefix: "{{ lang }}-$CI_COMMIT_REF_SLUG"
{% endif %}
    fallback_keys:
      - "{{ lang }}-$CI_DEFAULT_BRANCH"
      - "{{ lang }}-"
    paths:
{% if lang == 'python' %}
      - .venv/
      - .cache/uv/
{% elif lang == 'typescript' %}
{% if _mgr == 'pnpm' %}
      - node_modules/
      - .pnpm-store/
{% else %}
      - node_modules/
      - ~/.bun/install/cache/
{% endif %}
{% elif lang == 'go' %}
      - $GOPATH/pkg/mod/
{% elif lang == 'rust' %}
      - target/
      - ~/.cargo/registry/
{% else %}
      - .cache/
{% endif %}
{% endif %}
  script:
{% if lang == 'python' %}
    - {{ _mgr if _mgr else 'uv' }} run ruff check .
    - {{ _mgr if _mgr else 'uv' }} run ruff format --check .
{% if _test %}
    - {{ _mgr if _mgr else 'uv' }} run {{ _test }}
{% endif %}
{% elif lang == 'typescript' %}
{% if _mgr == 'pnpm' %}
    - pnpm install --frozen-lockfile
    - pnpm run biome check .
    - pnpm run tsc --noEmit
{% if _test %}
    - pnpm run {{ _test }}
{% endif %}
{% else %}
    - bun install --frozen-lockfile
    - bun run biome check .
    - bun run tsc --noEmit
{% if _test %}
    - bun run {{ _test }}
{% endif %}
{% endif %}
{% elif lang == 'go' %}
    - golangci-lint run ./...
    - go test ./...
{% elif lang == 'rust' %}
    - cargo fmt --check
    - cargo clippy -- -D warnings
    - cargo nextest run
{% else %}
    - echo "ci: {{ lang }}"
{% endif %}
{% endfor %}

{# ======================================================================
   MONOREPO-AFFECTED: parent-child pipelines (strategy:depend).
   ====================================================================== #}
{% elif ci_model == 'monorepo-affected' %}
{%- set _packages = monorepo_packages | default([]) %}
{% if _packages %}
{% for pkg in _packages %}
{%- set _pkg_safe = pkg | replace('/', '-') | replace('.', '-') %}

trigger:{{ _pkg_safe }}:
  stage: trigger
  trigger:
    include:
      - local: "{{ pkg }}/.gitlab-ci.yml"
    strategy: depend
  rules:
    - if: '$CI_COMMIT_BRANCH'
      changes:
        paths:
          - "{{ pkg }}/**/*"
        compare_to: "refs/heads/{{ default_branch | default('main') }}"
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
      changes:
        paths:
          - "{{ pkg }}/**/*"
{% endfor %}
{% else %}
# No monorepo_packages frozen: trigger child pipelines on any change.
# Freeze monorepo_packages via --data for path-filtered triggers.
{% if _languages %}
{% for lang in _languages %}

trigger:{{ lang }}:
  stage: trigger
  trigger:
    include:
      - local: ".gitlab/ci/{{ lang }}.yml"
    strategy: depend
  rules:
    - if: '$CI_COMMIT_BRANCH'
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
{% endfor %}
{% else %}

trigger:all:
  stage: trigger
  trigger:
    include:
      - local: ".gitlab/ci/child.yml"
    strategy: depend
  rules:
    - if: '$CI_COMMIT_BRANCH'
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
{% endif %}
{% endif %}

{# ======================================================================
   MERGE-QUEUE: merge trains (Premium/Ultimate).
   gitlab_tier=free renders merge-when-pipeline-succeeds fallback + warning.
   ====================================================================== #}
{% elif ci_model == 'merge-queue' %}
{% set _mq_langs = _languages if _languages else ['ci'] %}
{% for lang in _mq_langs %}
{%- set _facts = _lang_facts[lang] if (_languages and lang in _lang_facts and _lang_facts is mapping) else {} %}
{%- set _mgr   = _facts['manager'] if 'manager' in _facts else '' %}
{%- set _test  = _facts['test_runner'] if 'test_runner' in _facts else '' %}
{%- set _img   = _facts['image'] if 'image' in _facts else '' %}

{{ lang }}:
  stage: test
{% if _img %}
  image: {{ _img }}
{% endif %}
{% if ci_oidc_provider == 'gitlab' %}
  id_tokens:
    SIGSTORE_ID_TOKEN:
      aud: sigstore
{% endif %}
{% if gitlab_tier == 'premium_ultimate' %}
  rules:
    - if: '$CI_MERGE_TRAIN_PIPELINE == "true"'
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
    - if: '$CI_COMMIT_BRANCH == "{{ default_branch | default("main") }}"'
{% else %}
  # Free-tier fallback: runs on MR and default-branch push.
  # Enable merge trains by setting gitlab_tier=premium_ultimate.
  rules:
    - if: '$CI_PIPELINE_SOURCE == "merge_request_event"'
    - if: '$CI_COMMIT_BRANCH == "{{ default_branch | default("main") }}"'
{% endif %}
  script:
{% if lang == 'python' %}
    - {{ _mgr if _mgr else 'uv' }} run ruff check .
    - {{ _mgr if _mgr else 'uv' }} run ruff format --check .
{% if _test %}
    - {{ _mgr if _mgr else 'uv' }} run {{ _test }}
{% endif %}
{% elif lang == 'typescript' %}
{% if _mgr == 'pnpm' %}
    - pnpm install --frozen-lockfile
    - pnpm run biome check .
    - pnpm run tsc --noEmit
{% if _test %}
    - pnpm run {{ _test }}
{% endif %}
{% else %}
    - bun install --frozen-lockfile
    - bun run biome check .
    - bun run tsc --noEmit
{% if _test %}
    - bun run {{ _test }}
{% endif %}
{% endif %}
{% elif lang == 'go' %}
    - golangci-lint run ./...
    - go test ./...
{% elif lang == 'rust' %}
    - cargo fmt --check
    - cargo clippy -- -D warnings
    - cargo nextest run
{% else %}
    - echo "ci: {{ lang }}"
{% endif %}
{% endfor %}

{% endif %}{# end ci_model dispatch #}
{% endif %}{# end _guard_mode #}
