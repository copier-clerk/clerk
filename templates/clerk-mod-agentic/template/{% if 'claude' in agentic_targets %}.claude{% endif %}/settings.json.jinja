{#-
  .claude/settings.json — MANAGED.

  Rendered only when 'claude' is in agentic_targets (the parent directory is
  a Jinja-conditional path). Re-rendered byte-identically at reproduce.

  enableAllProjectMcpServers: when mcp_config=true (the MCP config is committed
  as .mcp.json, so Claude should auto-load it).

  extraKnownMarketplaces + enabledPlugins: when native_marketplace=true, records
  the plugins in the committed settings so Claude recognises them.
-#}
{
  "version": 1,
  "project": {
    "name": "{{ project_name | default('project', true) }}"{% if mcp_config or (native_marketplace and agentic_plugins | length > 0) %},{% endif %}

{% if mcp_config %}
    "enableAllProjectMcpServers": true{% if native_marketplace and agentic_plugins | length > 0 %},{% endif %}
{% endif %}
{% if native_marketplace and agentic_plugins | length > 0 %}
    "extraKnownMarketplaces": [
{% for plugin in agentic_plugins %}
      {
        "name": "{{ plugin.name }}",
        "ownerRepo": "{{ plugin.owner_repo }}"
      }{% if not loop.last %},{% endif %}
{% endfor %}
    ],
    "enabledPlugins": [
{% for plugin in agentic_plugins %}
      "{{ plugin.name }}"{% if not loop.last %},{% endif %}
{% endfor %}
    ]
{% endif %}
  }
}
