# .github/dependabot.yml — managed by bailiff-mod-dep-updates; do not edit by hand.
version: 2
updates:
{% for eco in dep_ecosystems %}
  - package-ecosystem: "{{ eco }}"
    directory: "/"
    schedule:
      interval: "weekly"
{% endfor %}
{% if not dep_ecosystems %}
  # No active ecosystems frozen (dep_ecosystems=[]): add entries per
  # https://docs.github.com/en/code-security/dependabot/dependabot-version-updates
  - package-ecosystem: "github-actions"
    directory: "/"
    schedule:
      interval: "weekly"
{% endif %}
