# lefthook.yml — managed by bailiff-mod-precommit (DO NOT EDIT BY HAND)
#
# Single writer: bailiff-mod-precommit owns this file (hook_manager+hook_blocks
# frozen-union contract, _cross-cutting §4, M1). Language hook blocks are
# injected via the frozen `hook_blocks` answer — never appended at runtime.
# All tool versions are managed via .mise.toml (bailiff-mod-base).

pre-commit:
  parallel: true
  commands:
    trailing-whitespace:
      run: |
        grep -rn " $" {staged_files} && exit 1 || true

    gitleaks:
      run: gitleaks protect --staged -v

    shellcheck:
      glob: "*.sh"
      run: shellcheck {staged_files}
{% if enable_typo_check %}

    typos:
      run: typos {staged_files}
{% endif %}
{% if enforce_conventional_commits %}

commit-msg:
  commands:
    conventional-commits:
      run: python3 .pre-commit-hooks/check-commit-msg.py {1}
{% endif %}
{% for block in hook_blocks %}
{{ block | indent(0) }}
{% endfor %}
