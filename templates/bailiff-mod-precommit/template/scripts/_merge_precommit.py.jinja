#!/usr/bin/env python3
# _merge_precommit.py — owner-side pre-commit fragment bundler
# Managed by bailiff-mod-precommit. DO NOT EDIT BY HAND.
#
# Reads all .pre-commit.d/*.yaml fragment files, deduplicates repos,
# emits .pre-commit-config.yaml deterministically.
#
# Rev-pin conflict (same repo URL, different revs): picks the highest rev
# and emits a warning to stderr. Never aborts — a lagging fragment must not
# veto a valid stack (spec 014 decisions-ledger.md R2).
#
# Inert when no .pre-commit.d/*.yaml fragments exist (e.g. hook_manager=none).
# Requires: Python 3.8+ + PyYAML (no other dependencies).

from __future__ import annotations

import sys
import warnings
from pathlib import Path

import yaml


def _rev_key(rev: str) -> tuple:
    """Comparable sort key for a revision string.

    Handles semantic versions (v1.2.3, 1.2.3), plain integers, and
    arbitrary strings. Higher = newer. Used for highest-wins comparison.
    """
    s = rev.lstrip("v")
    try:
        parts = tuple(int(x) for x in s.split("."))
        return (1, parts, "")
    except ValueError:
        pass
    return (0, (), rev)


def _pick_higher_rev(rev_a: str, rev_b: str) -> str:
    """Return the higher of two revision strings."""
    return rev_a if _rev_key(rev_a) >= _rev_key(rev_b) else rev_b


def main() -> int:
    dest = Path(".")
    fragment_dir = dest / ".pre-commit.d"

    fragments = sorted(fragment_dir.glob("*.yaml")) if fragment_dir.is_dir() else []
    if not fragments:
        return 0

    # repo_url -> {rev, hooks: list}
    merged: dict[str, dict] = {}
    # repo_url -> set of seen revs (for conflict detection)
    seen_revs: dict[str, set[str]] = {}
    # Top-level exclude: taken from the first fragment that declares it
    exclude: str | None = None

    for frag_path in fragments:
        try:
            data = yaml.safe_load(frag_path.read_text()) or {}
        except yaml.YAMLError as exc:
            print(f"_merge_precommit: skipping {frag_path.name}: {exc}", file=sys.stderr)
            continue

        if exclude is None and data.get("exclude"):
            exclude = str(data["exclude"])

        for repo_entry in data.get("repos", []):
            url = repo_entry.get("repo", "")
            rev = repo_entry.get("rev", "")
            hooks = repo_entry.get("hooks", [])
            if not url:
                continue

            if url not in merged:
                merged[url] = {"rev": rev, "hooks": list(hooks)}
                seen_revs[url] = {rev} if rev else set()
            else:
                existing = merged[url]
                # Rev-pin conflict: highest wins + warn
                if rev and rev not in seen_revs[url]:
                    seen_revs[url].add(rev)
                    if existing["rev"] != rev:
                        winner = _pick_higher_rev(existing["rev"], rev)
                        loser = rev if winner == existing["rev"] else existing["rev"]
                        warnings.warn(
                            f"_merge_precommit: rev-pin conflict for {url!r}: "
                            f"{existing['rev']!r} vs {rev!r} — using {winner!r} "
                            f"(discarding {loser!r})",
                            stacklevel=1,
                        )
                        existing["rev"] = winner

                # Dedup hooks by id
                existing_ids = {h.get("id") for h in existing["hooks"]}
                for hook in hooks:
                    if hook.get("id") not in existing_ids:
                        existing["hooks"].append(hook)
                        existing_ids.add(hook.get("id"))

    if not merged:
        return 0

    # Build output in deterministic order (sorted by repo URL)
    repos_out = []
    for url in sorted(merged):
        entry: dict = {"repo": url}
        if merged[url]["rev"]:
            entry["rev"] = merged[url]["rev"]
        entry["hooks"] = merged[url]["hooks"]
        repos_out.append(entry)

    config: dict = {}
    if exclude:
        config["exclude"] = exclude
    config["default_install_hook_types"] = ["pre-commit", "commit-msg"]
    config["repos"] = repos_out

    out_path = dest / ".pre-commit-config.yaml"
    out_path.write_text(
        "# .pre-commit-config.yaml — generated by _merge_precommit.py\n"
        "# DO NOT EDIT BY HAND — edit fragments in .pre-commit.d/ instead.\n"
        + yaml.dump(config, default_flow_style=False, allow_unicode=True, sort_keys=False)
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
