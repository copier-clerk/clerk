# cog.toml — managed by bailiff-mod-cocogitto; do not edit by hand.
# Cocogitto configuration for {{ _external_data.base.project_name | default('this project', true) }}.
# Release actions (cog bump / cog changelog) are the project's to run —
# bailiff never bumps, tags, or writes changelog entries at scaffold time.
{% if _external_data.base.layout == 'monorepo' %}
# Monorepo mode: per-package tags <package>-vX.Y.Z; no umbrella global tag.
generate_mono_repository_global_tag = false
tag_prefix = "v"

[monorepo]
{% for pkg in _external_data.moon.monorepo_packages %}
[monorepo.packages.{{ pkg | replace('/', '-') }}]
path = "{{ pkg }}"
{% endfor %}
{% else %}
tag_prefix = "v"

[changelog]
path = "CHANGELOG.md"
{% endif %}
