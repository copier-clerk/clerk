# justfile — generated by bailiff-mod-justfile (seed-once; safe to edit)
# Run `just` or `just --list` to see available recipes.

# Show available recipes
default:
    @just --list

{% if language == "python" %}
# Run tests
test:
    uv run pytest

# Lint and format (hook_manager: {{ hook_manager }})
{%- if hook_manager == "pre-commit" %}
lint:
    pre-commit run --all-files
{%- elif hook_manager == "lefthook" %}
lint:
    lefthook run pre-commit
{%- else %}
lint:
    uv run ruff check . && uv run ruff format --check .
{%- endif %}

# Build distribution packages
build:
    uv build

# Start development mode (editable install)
dev:
    uv pip install -e .

# Clean build artefacts
clean:
    rm -rf dist build .pytest_cache .ruff_cache .mypy_cache __pycache__

{% elif language == "ts" %}
# Run tests
test:
    {{ js_pkg_manager }} test

# Lint and format (hook_manager: {{ hook_manager }})
{%- if hook_manager == "pre-commit" %}
lint:
    pre-commit run --all-files
{%- elif hook_manager == "lefthook" %}
lint:
    lefthook run pre-commit
{%- else %}
lint:
    {{ js_pkg_manager }} run lint
{%- endif %}

# Build output
build:
    {{ js_pkg_manager }} run build

# Start development mode with watch
dev:
    {{ js_pkg_manager }} run dev

# Clean build artefacts
clean:
    rm -rf dist node_modules/.cache .next out

{% elif language == "go" %}
# Run tests
test:
    go test ./...

# Lint and format (hook_manager: {{ hook_manager }})
{%- if hook_manager == "pre-commit" %}
lint:
    pre-commit run --all-files
{%- elif hook_manager == "lefthook" %}
lint:
    lefthook run pre-commit
{%- else %}
lint:
    go vet ./... && gofmt -l .
{%- endif %}

# Build binary
build:
    go build ./...

# Run the application
dev:
    go run ./...

# Clean build artefacts
clean:
    go clean ./...

{% elif language == "rust" %}
# Run tests
test:
    cargo test

# Lint and format (hook_manager: {{ hook_manager }})
{%- if hook_manager == "pre-commit" %}
lint:
    pre-commit run --all-files
{%- elif hook_manager == "lefthook" %}
lint:
    lefthook run pre-commit
{%- else %}
lint:
    cargo clippy -- -D warnings && cargo fmt --check
{%- endif %}

# Build debug binary (use `cargo build --release` for optimised release)
build:
    cargo build
    # Release: cargo build --release

# Run the application
dev:
    cargo run

# Clean build artefacts
clean:
    cargo clean

{% else %}
# Run tests — language not configured; replace this stub
test:
    @echo "bailiff-mod-justfile: 'test' recipe not configured (language not set). Edit justfile." >&2 && exit 1

# Lint — language not configured; replace this stub
lint:
    @echo "bailiff-mod-justfile: 'lint' recipe not configured (language not set). Edit justfile." >&2 && exit 1

# Build — language not configured; replace this stub
build:
    @echo "bailiff-mod-justfile: 'build' recipe not configured (language not set). Edit justfile." >&2 && exit 1

# Dev — language not configured; replace this stub
dev:
    @echo "bailiff-mod-justfile: 'dev' recipe not configured (language not set). Edit justfile." >&2 && exit 1

# Clean build artefacts — language not configured; replace this stub
clean:
    @echo "bailiff-mod-justfile: 'clean' recipe not configured (language not set). Edit justfile." >&2 && exit 1

{% endif %}
